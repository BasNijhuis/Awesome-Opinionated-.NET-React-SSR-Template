# Pin exact dependency versions — no `^`/`~` ranges in package.json.
save-exact=true
save-prefix=

# Don't re-verify/re-install deps before every `pnpm run`. The nested install this triggers (e.g.
# when the web `api:generate` shells into the `scripts` member) destructively rewrites
# pnpm-workspace.yaml under pnpm 11.8. CI/dev run an explicit install first anyway.
verify-deps-before-run=false
