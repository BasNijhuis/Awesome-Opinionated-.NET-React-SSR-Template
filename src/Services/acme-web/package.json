{
  "name": "acme-web",
  "private": true,
  "type": "module",
  "scripts": {
    "api:generate": "dotnet build ../Acme.Api/Acme.Api.csproj && openapi-ts && tsx scripts/generate-contract-types.ts",
    "build": "pnpm run api:generate && react-router build",
    "dev": "react-router dev",
    "start": "node ./server.js",
    "typecheck": "pnpm run api:generate && react-router typegen && tsc",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "postinstall": "tsx scripts/fix-biome-lsp-path.ts",
    "prepare": "pnpm run api:generate"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/cinzel": "^5.2.8",
    "@microsoft/signalr": "10.0.0",
    "@react-router/express": "8.0.1",
    "@react-router/node": "8.0.1",
    "@react-router/serve": "8.0.1",
    "compression": "1.8.1",
    "express": "5.2.1",
    "http-proxy-middleware": "4.1.1",
    "i18next": "^26.3.1",
    "isbot": "5.1.43",
    "morgan": "1.11.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-i18next": "^17.0.8",
    "react-router": "8.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@hey-api/openapi-ts": "0.98.2",
    "@playwright/test": "1.61.0",
    "@react-router/dev": "8.0.1",
    "@tailwindcss/vite": "4.3.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "4.1.9",
    "jsdom": "29.1.1",
    "tailwindcss": "4.3.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.9"
  },
  "packageManager": "pnpm@11.8.0"
}
