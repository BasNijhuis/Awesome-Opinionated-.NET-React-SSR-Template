{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "src/Services/acme-web/**",
      "!src/Services/acme-web/app/lib/api/generated",
      "!src/Services/acme-web/.react-router",
      "!src/Services/acme-web/**/*.css",
      "scripts/**",
      "tests/e2e/**"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "style": { "noNonNullAssertion": "off" },
      "correctness": { "useExhaustiveDependencies": "warn" }
    }
  },
  "javascript": { "formatter": { "quoteStyle": "double" } }
}
